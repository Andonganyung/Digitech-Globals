rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is admin
    function isAdmin() {
      return isSignedIn() && 
             firestore.get(/databases/(default)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Validate file size (5MB max)
    function isValidSize() {
      return request.resource.size <= 5 * 1024 * 1024;
    }
    
    // Validate file type (only images and PDFs)
    function isValidType() {
      return request.resource.contentType.matches('image/.*') 
          || request.resource.contentType == 'application/pdf';
    }
    
    // ============================================
    // DOCUMENT UPLOADS (user applications)
    // ============================================
    match /documents/{userId}/{fileName} {
      // Users can upload to their own folder only
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isValidSize()
                   && isValidType();
      
      // Users can read their own files, admins can read all
      allow read: if isSignedIn() && (
                     request.auth.uid == userId
                     || isAdmin()
                  );
      
      // Only owner can delete their files
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
    
    // ============================================
    // CERTIFICATES (generated PDFs)
    // ============================================
    match /certificates/{userId}/{certFileName} {
      // Anyone can read (for verification)
      allow read: if true;
      
      // Only admins can upload
      allow write: if isAdmin()
                   && isValidSize()
                   && request.resource.contentType == 'application/pdf';
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // ============================================
    // COURSE MATERIALS (if used)
    // ============================================
    match /courses/{courseId}/{material} {
      // Enrolled users and admins can read
      allow read: if isSignedIn();
      
      // Only admins can upload
      allow write, delete: if isAdmin();
    }
    
    // ============================================
    // PROFILE PICTURES (if used)
    // ============================================
    match /profilePictures/{userId}/{fileName} {
      // User can upload their own picture
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isValidSize()
                   && request.resource.contentType.matches('image/.*');
      
      // Anyone can view profile pictures
      allow read: if true;
      
      // Only owner can delete
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
    
    // ============================================
    // BLOG IMAGES (if used)
    // ============================================
    match /blog/{postId}/{fileName} {
      // Everyone can read
      allow read: if true;
      
      // Only admins can upload/delete
      allow write, delete: if isAdmin();
    }
    
    // ============================================
    // DEFAULT: DENY ALL
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
